
DATABASE_URL="file:"
NEXTAUTH_URL=
# Leave empty for same-origin API calls (recommended). Set only if API is on another host.
NEXT_PUBLIC_API_BASE_URL=
NEXTAUTH_SECRET=""
DEFAULT_ADMIN_PASSWORD=""
FIREBIRD_HOST=
FIREBIRD_PORT=
FIREBIRD_DATABASE=""
FIREBIRD_USER=""
FIREBIRD_PASSWORD=""

# Cron (server.ts uniquement — npm run dev / npm start)
CRON_ENABLED=true
CRON_LOG_DIR=
# Clients Firebird → SQLite (toutes les 2 minutes par défaut)
CRON_CUSTOMERS_SYNC_ENABLED=true
CRON_CUSTOMERS_SYNC_SCHEDULE=*/2 * * * *
# Lancer une sync immédiatement au démarrage du serveur
CRON_CUSTOMERS_SYNC_ON_START=false