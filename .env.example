
DATABASE_URL="file:"
NEXTAUTH_URL=
# Leave empty for same-origin API calls (recommended). Set only if API is on another host.
NEXT_PUBLIC_API_BASE_URL=
NEXTAUTH_SECRET=""
DEFAULT_ADMIN_PASSWORD=""
FIREBIRD_HOST=
FIREBIRD_PORT=
FIREBIRD_DATABASE=""
FIREBIRD_USER=""
FIREBIRD_PASSWORD=""

# Cron (server.ts only — npm run dev / npm start)
CRON_ENABLED=true
CRON_LOG_DIR=
# Firebird to SQLite sync (every 2 minutes by default)
CRON_CUSTOMERS_SYNC_ENABLED=true
CRON_CUSTOMERS_SYNC_SCHEDULE=*/2 * * * *
# Run a sync immediately at server startup
CRON_CUSTOMERS_SYNC_ON_START=false

# Rate limiting 
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH_MAX=20
# RATE_LIMIT_STATS_MAX=45
# RATE_LIMIT_HEAVY_READ_MAX=90
# RATE_LIMIT_HEAVY_WRITE_MAX=60
# RATE_LIMIT_UPLOAD_MAX=20
# RATE_LIMIT_ADMIN_MAX=30
# RATE_LIMIT_FIREBIRD_MAX=25